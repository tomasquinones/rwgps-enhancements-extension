{
  "manifest_version": 3,
  "name": "RideWithGPS Enhancements",
  "version": "2026.4.12",
  "version_name": "20260412a",
  "description": "Unofficial enhancements for RideWithGPS: activity streak stats on profile pages and speed-colored map tracks and elevation graphs on trip and route pages.",
  "homepage_url": "https://github.com/tomasquinones/rwgps-enhancements-extension",
  "browser_specific_settings": {
    "gecko": {
      "id": "rwgps-enhancements@tomasquinones",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "RWGPS Enhancements"
  },
  "content_scripts": [
    {
      "matches": ["*://ridewithgps.com/*"],
      "js": ["content/content.js", "content/shared.js", "content/bridge.js", "content/speedcolors.js", "content/traveldir.js", "content/climbs.js", "content/descents.js", "content/segments.js", "content/daylight.js", "content/quicklaps.js", "content/trip-more-tools.js", "content/menu.js", "content/goals.js", "content/calendar.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://ridewithgps.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-user.js", "content/page-bridge.js"],
      "matches": ["*://ridewithgps.com/*"]
    }
  ]
}
