{
  "manifest_version": 2,
  "name": "RideWithGPS Activity Streak",
  "version": "1.0",
  "description": "Shows your activity streak on RideWithGPS profile pages",
  "content_scripts": [
    {
      "matches": ["*://ridewithgps.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "*://ridewithgps.com/*"
  ]
}
